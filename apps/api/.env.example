NODE_ENV=development
PORT=4000

DATABASE_URL=postgres://shopstream:shopstream@localhost:5433/shopstream
REDIS_URL=redis://localhost:6380

JWT_SECRET=replace-me-in-production-32-chars-min
JWT_ISSUER=shopstream-api

# Feature flags — snake_case, default OFF
FF_GUEST_CHECKOUT_ENABLED=false
FF_ACCOUNT_UPSELL_AFTER_GUEST=false

# payx-sdk sandbox
PAYX_API_KEY=sk_test_replace_me
PAYX_PUBLIC_KEY=pk_test_replace_me
PAYX_API_BASE=https://api.sandbox.payx.example/v1

# OpenTelemetry
OTEL_SERVICE_NAME=shopstream-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
